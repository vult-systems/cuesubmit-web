# CueSubmit Web Configuration
# Copy this file to .env.local for local development

# Mode: "online" connects to REST Gateway, "offline" uses mock data
CUEWEB_MODE=online

# REST Gateway URL (OpenCue REST API)
# For production (on same machine as gateway): http://127.0.0.1:8448
# For remote development: http://10.40.14.25:8448
CUEWEB_API_BASE=http://10.40.14.25:8448
REST_GATEWAY_URL=http://10.40.14.25:8448

# Session secrets (use strong random values in production)
JWT_SECRET=your-production-secret-32chars
SESSION_SECRET=cuesubmit-session-secret-key-32ch

# Database path for SQLite
DATABASE_PATH=./data/cuesubmit.db

# Initial admin password (only used on first run)
ADMIN_INITIAL_PASSWORD=admin123
